<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/laras_home_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/widget_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_artwork"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/laras_home_widget_artwork_background"
            android:contentDescription="Artwork"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_stat_laras" />

        <LinearLayout
            android:id="@+id/widget_content_column"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/widget_badge_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/laras_home_widget_chip_background"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingLeft="10dp"
                    android:paddingTop="5dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="5dp"
                    android:text="Jeda"
                    android:textColor="#FFF7F4FF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/laras_home_widget_brand_chip_background"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingLeft="10dp"
                    android:paddingTop="5dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="5dp"
                    android:text="Laras"
                    android:textColor="#FFF59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Tidak ada lagu"
                android:textColor="#FFFFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Putar lagu dari Laras"
                android:textColor="#D9FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/widget_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Offline player"
                android:textColor="#A7A3B8"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_footer_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Offline-first library"
            android:textColor="#B3F8FAFC"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/widget_controls_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/laras_home_widget_control_background"
                android:contentDescription="Previous"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_previous" />

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/laras_home_widget_control_primary_background"
                android:contentDescription="Play pause"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_play" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/laras_home_widget_control_background"
                android:contentDescription="Next"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_next" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
